  }
} else if (length(cutoffs) == 1) {
  # Shade lightly around the single cutoff
  c1 <- cutoffs[1]
  abline(v = c1, lty = 2, lwd = 2, col = "#6c5ce7")
}

# Legend
legend("topright",
       legend = c("Component 1", "Component 2", "Mixture", "Cutoff"),
       col = c("#0984e3", "#00b894", "#e17055", "#6c5ce7"),
       lwd = c(2, 2, 2.5, 1.8),
       lty = c(2, 2, 1, 2),
       bg = "white",
       box.lwd = 0.5,
