<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bimodal Cq Distribution Analyzer - WebR</title>
    <style>
        :root {
            --bg: #f5f6fa;
            --card-bg: #ffffff;
            --text: #2d3436;
            --text-secondary: #636e72;
            --accent: #0984e3;
            --accent-hover: #0767b3;
            --border: #dfe6e9;
            --shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
            --shadow-lg: 0 8px 30px rgba(0, 0, 0, 0.10);
            --radius: 12px;
            --radius-sm: 8px;
            --success: #00b894;
            --warning: #fdcb6e;
            --danger: #e17055;
            --font: 'Inter', 'Segoe UI', system-ui, -apple-system, sans-serif;
            --mono: 'JetBrains Mono', 'Fira Code', 'Consolas', monospace;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: var(--font);
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            line-height: 1.6;
            padding: 20px;
        }

        .container {
            max-width: 960px;
            margin: 0 auto;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        /* Header */
        .header {
            text-align: center;
            padding: 10px 0;
        }
        .header h1 {
            font-size: 1.9rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #1a1a2e;
            margin-bottom: 4px;
        }
        .header .badge {
            display: inline-block;
            background: #e8f4fd;
            color: var(--accent);
            font-size: 0.8rem;
            font-weight: 600;
            padding: 4px 12px;
            border-radius: 20px;
            letter-spacing: 0.03em;
        }

        /* Cards */
        .card {
            background: var(--card-bg);
            border-radius: var(--radius);
            padding: 24px;
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            transition: box-shadow 0.2s;
        }
        .card:hover {
            box-shadow: var(--shadow-lg);
        }
        .card-title {
            font-size: 1.05rem;
            font-weight: 700;
            margin-bottom: 14px;
            color: #1a1a2e;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .card-title .icon {
            font-size: 1.3rem;
        }

        /* Upload area */
        .upload-zone {
            border: 2px dashed var(--border);
            border-radius: var(--radius);
            padding: 40px 20px;
            text-align: center;
            cursor: pointer;
            transition: all 0.25s;
            background: #fafbfc;
            position: relative;
        }
        .upload-zone:hover,
        .upload-zone.drag-over {
            border-color: var(--accent);
            background: #f0f7ff;
        }
        .upload-zone input[type="file"] {
            position: absolute;
            inset: 0;
            opacity: 0;
            cursor: pointer;
        }
        .upload-zone .upload-icon {
            font-size: 3rem;
            margin-bottom: 8px;
            opacity: 0.7;
        }
        .upload-zone .upload-text {
            font-weight: 600;
            color: var(--text);
        }
        .upload-zone .upload-hint {
            font-size: 0.85rem;
            color: var(--text-secondary);
            margin-top: 4px;
        }
        .file-info {
            margin-top: 10px;
            font-size: 0.9rem;
            color: var(--accent);
            font-weight: 500;
            display: none;
            align-items: center;
            gap: 6px;
        }
        .file-info.visible {
            display: flex;
        }

        /* Controls */
        .controls-row {
            display: flex;
            gap: 14px;
            flex-wrap: wrap;
            align-items: flex-end;
        }
        .control-group {
            display: flex;
            flex-direction: column;
            gap: 5px;
            flex: 1;
            min-width: 150px;
        }
        .control-group label {
            font-size: 0.82rem;
            font-weight: 600;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.03em;
        }
        .control-group select,
        .control-group input {
            font-family: var(--font);
            font-size: 0.95rem;
            padding: 10px 14px;
            border: 1.5px solid var(--border);
            border-radius: var(--radius-sm);
            background: #fafbfc;
            color: var(--text);
            transition: border-color 0.2s;
            width: 100%;
        }
        .control-group select:focus,
        .control-group input:focus {
            outline: none;
            border-color: var(--accent);
            box-shadow: 0 0 0 3px rgba(9, 132, 227, 0.08);
        }

        /* Buttons */
        .btn {
            font-family: var(--font);
            font-size: 0.95rem;
            font-weight: 600;
            padding: 11px 22px;
            border: none;
            border-radius: var(--radius-sm);
            cursor: pointer;
            transition: all 0.2s;
            letter-spacing: 0.02em;
            white-space: nowrap;
        }
        .btn-primary {
            background: var(--accent);
            color: #fff;
        }
        .btn-primary:hover {
            background: var(--accent-hover);
            transform: translateY(-1px);
            box-shadow: 0 4px 14px rgba(9, 132, 227, 0.3);
        }
        .btn-primary:disabled {
            background: #b2bec3;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }
        .btn-outline {
            background: #fff;
            color: var(--accent);
            border: 1.5px solid var(--accent);
        }
        .btn-outline:hover {
            background: #f0f7ff;
        }
        .btn-sm {
            font-size: 0.82rem;
            padding: 7px 14px;
        }

        /* Loading */
        .loading-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(255, 255, 255, 0.85);
            z-index: 1000;
            justify-content: center;
            align-items: center;
            flex-direction: column;
            gap: 14px;
        }
        .loading-overlay.active {
            display: flex;
        }
        .spinner {
            width: 44px;
            height: 44px;
            border: 4px solid var(--border);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }
        .loading-text {
            font-weight: 600;
            color: var(--text);
            font-size: 0.95rem;
        }
        .loading-sub {
            font-size: 0.82rem;
            color: var(--text-secondary);
        }

        /* Plot container */
        .plot-container {
            text-align: center;
            min-height: 200px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #fafbfc;
            border-radius: var(--radius-sm);
            overflow: hidden;
        }
        .plot-container canvas {
            max-width: 100%;
            height: auto !important;
            display: block;
        }
        .plot-placeholder {
            color: var(--text-secondary);
            font-size: 0.9rem;
            padding: 40px;
        }

        /* Results */
        .results-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 14px;
        }
        .result-badge {
            background: #f8f9fa;
            border-radius: var(--radius-sm);
            padding: 16px;
            text-align: center;
            border: 1px solid var(--border);
        }
        .result-badge .value {
            font-size: 1.5rem;
            font-weight: 700;
            color: #1a1a2e;
            font-family: var(--mono);
        }
        .result-badge .label {
            font-size: 0.78rem;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.03em;
            margin-top: 2px;
        }
        .verdict {
            font-size: 1.15rem;
            font-weight: 700;
            padding: 10px 18px;
            border-radius: 20px;
            display: inline-block;
            letter-spacing: 0.02em;
        }
        .verdict.bimodal-strong {
            background: #d4edda;
            color: #155724;
        }
        .verdict.bimodal-moderate {
            background: #fff3cd;
            color: #856404;
        }
        .verdict.bimodal-weak {
            background: #ffeaa7;
            color: #6c5b00;
        }
        .verdict.unimodal {
            background: #f1f3f4;
            color: #555;
        }

        /* Status bar */
        .status-bar {
            font-size: 0.82rem;
            color: var(--text-secondary);
            text-align: center;
            padding: 4px;
        }
        .status-bar .dot {
            display: inline-block;
            width: 8px;
            height: 8px;
            border-radius: 50%;
            margin-right: 6px;
        }
        .dot.ready {
            background: var(--success);
        }
        .dot.loading {
            background: var(--warning);
            animation: pulse 1s infinite;
        }
        .dot.error {
            background: var(--danger);
        }
        @keyframes pulse {
            0%,
            100% {
                opacity: 1;
            }
            50% {
                opacity: 0.3;
            }
        }

        /* Responsive */
        @media (max-width: 640px) {
            .header h1 {
                font-size: 1.4rem;
            }
            .card {
                padding: 16px;
            }
            .controls-row {
                flex-direction: column;
            }
            .results-grid {
                grid-template-columns: repeat(2, 1fr);
            }
        }
    </style>
</head>
<body>

    <div class="container">
        <!-- Header -->
        <div class="header">
            <h1>🔬 Bimodal Cq Distribution Analyzer</h1>
            <span class="badge">Powered by WebR · R in the Browser</span>
        </div>

        <!-- Status -->
        <div class="status-bar" id="statusBar">
            <span class="dot loading" id="statusDot"></span>
            <span id="statusText">Initializing WebR engine...</span>
        </div>

        <!-- Upload Card -->
        <div class="card">
            <div class="card-title"><span class="icon">📁</span> Upload CSV File</div>
            <div class="upload-zone" id="uploadZone">
                <div class="upload-icon">📤</div>
                <div class="upload-text">Click to upload or drag &amp; drop</div>
                <div class="upload-hint">CSV format with header row (e.g., exported from qPCR software)</div>
                <input type="file" id="fileInput" accept=".csv">
            </div>
            <div class="file-info" id="fileInfo">
                ✅ <span id="fileName"></span> · <span id="fileRowCount"></span> rows · <span id="fileColCount"></span> columns
            </div>
        </div>

        <!-- Configuration Card -->
        <div class="card" id="configCard">
            <div class="card-title"><span class="icon">⚙️</span> Analysis Configuration</div>
            <div class="controls-row">
                <div class="control-group">
                    <label for="colSelect">Cq Column</label>
                    <select id="colSelect" disabled>
                        <option value="">-- Upload a CSV first --</option>
                    </select>
                </div>
                <div class="control-group">
                    <label for="thresholdInput">Filter: Keep values &lt; threshold</label>
                    <input type="number" id="thresholdInput" value="40" step="0.1" min="0" max="100">
                </div>
                <div class="control-group" style="flex: 0 0 auto; justify-content: flex-end;">
                    <label>&nbsp;</label>
                    <button class="btn btn-outline btn-sm" id="sampleBtn" title="Generate sample bimodal data for testing">
                        🧪 Use Sample Data
                    </button>
                </div>
            </div>
            <div style="margin-top: 16px;">
                <button class="btn btn-primary" id="analyzeBtn" disabled>
                    🔍 Analyze Bimodality
                </button>
            </div>
        </div>

        <!-- Plot Card -->
        <div class="card" id="plotCard">
            <div class="card-title"><span class="icon">📈</span> Histogram & Mixture Model</div>
            <div class="plot-container" id="plotContainer">
                <div class="plot-placeholder" id="plotPlaceholder">
                    Run an analysis to see the histogram with fitted mixture model here.
                </div>
            </div>
        </div>

        <!-- Results Card -->
        <div class="card" id="resultsCard" style="display:none;">
            <div class="card-title"><span class="icon">📊</span> Results</div>
            <div style="text-align:center;margin-bottom:16px;">
                <span class="verdict" id="verdictBadge"></span>
            </div>
            <div class="results-grid" id="resultsGrid"></div>
        </div>
    </div>

    <!-- Loading overlay -->
    <div class="loading-overlay" id="loadingOverlay">
        <div class="spinner"></div>
        <div class="loading-text" id="loadingText">Analyzing...</div>
        <div class="loading-sub" id="loadingSub"></div>
    </div>

    <!-- WebR module -->
    <script type="module">
        import { WebR } from 'https://webr.r-wasm.org/latest/webr.mjs';

        // ─────────────────────────────────────
        // DOM references
        // ─────────────────────────────────────
        const statusDot = document.getElementById('statusDot');
        const statusText = document.getElementById('statusText');
        const uploadZone = document.getElementById('uploadZone');
        const fileInput = document.getElementById('fileInput');
        const fileInfo = document.getElementById('fileInfo');
        const fileNameEl = document.getElementById('fileName');
        const fileRowCountEl = document.getElementById('fileRowCount');
        const fileColCountEl = document.getElementById('fileColCount');
        const colSelect = document.getElementById('colSelect');
        const thresholdInput = document.getElementById('thresholdInput');
        const analyzeBtn = document.getElementById('analyzeBtn');
        const sampleBtn = document.getElementById('sampleBtn');
        const plotContainer = document.getElementById('plotContainer');
        const plotPlaceholder = document.getElementById('plotPlaceholder');
        const resultsCard = document.getElementById('resultsCard');
        const verdictBadge = document.getElementById('verdictBadge');
        const resultsGrid = document.getElementById('resultsGrid');
        const loadingOverlay = document.getElementById('loadingOverlay');
        const loadingText = document.getElementById('loadingText');
        const loadingSub = document.getElementById('loadingSub');

        // ─────────────────────────────────────
        // State
        // ─────────────────────────────────────
        let webR = null;
        let webRReady = false;
        let csvData = null; // raw CSV text
        let csvColumns = [];
        let csvRowCount = 0;
        let currentPlotCanvas = null;

        // ─────────────────────────────────────
        // Status helpers
        // ─────────────────────────────────────
        function setStatus(state, text) {
            statusDot.className = 'dot ' + state;
            statusText.textContent = text;
        }

        function showLoading(text, sub = '') {
            loadingText.textContent = text;
            loadingSub.textContent = sub;
            loadingOverlay.classList.add('active');
        }

        function hideLoading() {
            loadingOverlay.classList.remove('active');
        }

        // ─────────────────────────────────────
        // Initialize WebR
        // ─────────────────────────────────────
        async function initWebR() {
            setStatus('loading', 'Downloading WebR engine (~25MB)...');
            try {
                webR = new WebR({
                    interactive: false,
                });
                await webR.init();
                webRReady = true;
                setStatus('ready', 'WebR engine ready. Upload a CSV to begin.');
                console.log('WebR initialized successfully');
            } catch (err) {
                setStatus('error', 'Failed to initialize WebR: ' + err.message);
                console.error('WebR init error:', err);
                throw err;
            }
        }

        // ─────────────────────────────────────
        // CSV Parsing (JS side, for column detection)
        // ─────────────────────────────────────
        function parseCSVHeaders(text) {
            const lines = text.trim().split(/\r?\n/);
            if (lines.length === 0) return { columns: [], rowCount: 0 };
            // Detect delimiter
            const firstLine = lines[0];
            let delim = ',';
            if (firstLine.includes('\t')) delim = '\t';
            else if (firstLine.includes(';')) delim = ';';
            else if (firstLine.includes('|')) delim = '|';

            const headers = firstLine.split(delim).map(h => h.trim().replace(/^"|"$/g, '').replace(/^'|'$/g, ''));
            const rowCount = lines.length - 1; // exclude header
            return { columns: headers, rowCount: Math.max(0, rowCount), delimiter: delim };
        }

        // ─────────────────────────────────────
        // Handle file upload
        // ─────────────────────────────────────
        function handleFile(file) {
            if (!file.name.toLowerCase().endsWith('.csv')) {
                alert('Please upload a CSV file.');
                return;
            }
            const reader = new FileReader();
            reader.onload = (e) => {
                csvData = e.target.result;
                const parsed = parseCSVHeaders(csvData);
                csvColumns = parsed.columns;
                csvRowCount = parsed.rowCount;
                fileNameEl.textContent = file.name;
                fileRowCountEl.textContent = csvRowCount.toLocaleString();
                fileColCountEl.textContent = csvColumns.length;
                fileInfo.classList.add('visible');

                // Populate column selector
                colSelect.innerHTML = '<option value="">-- Select Cq column --</option>';
                csvColumns.forEach(col => {
                    const option = document.createElement('option');
                    option.value = col;
                    option.textContent = col;
                    // Auto-select if column name looks like a Cq column
                    const lower = col.toLowerCase();
                    if (lower.includes('cq') || lower.includes('ct') || lower === 'cq_mean' || lower ===
                        'ct_mean' || lower.includes('pia')) {
                        option.selected = true;
                    }
                    colSelect.appendChild(option);
                });
                colSelect.disabled = false;
                analyzeBtn.disabled = false;
                // Reset results
                resetResults();
                setStatus('ready', `CSV loaded: ${file.name} (${csvRowCount} rows, ${csvColumns.length} columns)`);
            };
            reader.readAsText(file);
        }

        fileInput.addEventListener('change', (e) => {
            if (e.target.files.length > 0) {
                handleFile(e.target.files[0]);
            }
        });

        // Drag and drop
        uploadZone.addEventListener('dragover', (e) => {
            e.preventDefault();
            uploadZone.classList.add('drag-over');
        });
        uploadZone.addEventListener('dragleave', () => {
            uploadZone.classList.remove('drag-over');
        });
        uploadZone.addEventListener('drop', (e) => {
            e.preventDefault();
            uploadZone.classList.remove('drag-over');
            if (e.dataTransfer.files.length > 0) {
                handleFile(e.dataTransfer.files[0]);
            }
        });

        // ─────────────────────────────────────
        // Reset results display
        // ─────────────────────────────────────
        function resetResults() {
            resultsCard.style.display = 'none';
            verdictBadge.textContent = '';
            verdictBadge.className = 'verdict';
            resultsGrid.innerHTML = '';
            // Clear plot
            if (currentPlotCanvas && currentPlotCanvas.parentNode) {
                currentPlotCanvas.parentNode.removeChild(currentPlotCanvas);
            }
            currentPlotCanvas = null;
            plotPlaceholder.style.display = 'block';
            plotPlaceholder.textContent = 'Run an analysis to see the histogram with fitted mixture model here.';
        }

        // ─────────────────────────────────────
        // The R analysis code (as a string template)
        // ─────────────────────────────────────
        function buildRCode(columnName, threshold, useSampleData) {
            let rCode = '';

            if (useSampleData) {
                // Generate sample bimodal data
                rCode += `
# Generate sample bimodal Cq data
set.seed(42)
group1 <- rnorm(400, mean = 26, sd = 1.8)
group2 <- rnorm(250, mean = 33, sd = 2.5)
x_all <- c(group1, group2)
x_all <- x_all + rnorm(length(x_all), 0, 0.4)
x_all <- x_all[x_all > 10 & x_all < 45]
x_raw <- x_all
`;
            } else {
                // Read from uploaded CSV
                rCode += `
# Read CSV data
dt <- read.csv('/home/webr/data.csv', stringsAsFactors = FALSE, check.names = FALSE)
x_raw <- as.numeric(dt[["${columnName.replace(/"/g, '\\"')}"]])
`;
            }

            rCode += `
# ── Custom EM Algorithm for 2-Component Normal Mixture ──
em_two_normals <- function(x, max_iter = 800, tol = 1e-6, n_starts = 3) {
  n <- length(x)
  x_sorted <- sort(x)
  
  best_result <- NULL
  best_log_lik <- -Inf
  
  for (start in 1:n_starts) {
    # Initialize with different quantile splits
    if (start == 1) {
      split_pt <- median(x)
    } else if (start == 2) {
      split_pt <- quantile(x, 0.4 + 0.05 * start)
    } else {
      split_pt <- quantile(x, 0.35 + 0.06 * start)
    }
    
    g1 <- x[x <= split_pt]
    g2 <- x[x > split_pt]
    
    if (length(g1) < 3 || length(g2) < 3) next
    
    mu1 <- mean(g1)
    mu2 <- mean(g2)
    sigma1 <- sd(g1)
    sigma2 <- sd(g2)
    if (is.na(sigma1) || sigma1 < 0.01) sigma1 <- sd(x) * 0.5
    if (is.na(sigma2) || sigma2 < 0.01) sigma2 <- sd(x) * 0.5
    lambda1 <- length(g1) / n
    lambda2 <- 1 - lambda1
    
    log_lik_old <- -Inf
    
    for (iter in 1:max_iter) {
      # E-step: compute responsibilities
      comp1 <- lambda1 * dnorm(x, mu1, sigma1)
      comp2 <- lambda2 * dnorm(x, mu2, sigma2)
      total <- comp1 + comp2
      total[total < 1e-300] <- 1e-300
      resp1 <- comp1 / total
      resp2 <- comp2 / total
      
      # M-step: update parameters
      lambda1_new <- mean(resp1)
      lambda2_new <- 1 - lambda1_new
      mu1_new <- sum(resp1 * x) / sum(resp1)
      mu2_new <- sum(resp2 * x) / sum(resp2)
      
      diff1 <- x - mu1_new
      diff2 <- x - mu2_new
      sigma1_new <- sqrt(sum(resp1 * diff1^2) / sum(resp1))
      sigma2_new <- sqrt(sum(resp2 * diff2^2) / sum(resp2))
      
      # Regularize
      if (sigma1_new < 0.005) sigma1_new <- 0.01
      if (sigma2_new < 0.005) sigma2_new <- 0.01
      if (lambda1_new < 0.02) lambda1_new <- 0.02
      if (lambda1_new > 0.98) lambda1_new <- 0.98
      lambda2_new <- 1 - lambda1_new
      
      # Compute log-likelihood
      comp1_new <- lambda1_new * dnorm(x, mu1_new, sigma1_new)
      comp2_new <- lambda2_new * dnorm(x, mu2_new, sigma2_new)
      total_new <- comp1_new + comp2_new
      total_new[total_new < 1e-300] <- 1e-300
      log_lik_new <- sum(log(total_new))
      
      # Check convergence
      if (!is.finite(log_lik_new)) break
      if (abs(log_lik_new - log_lik_old) < tol) {
        lambda1 <- lambda1_new; lambda2 <- lambda2_new
        mu1 <- mu1_new; mu2 <- mu2_new
        sigma1 <- sigma1_new; sigma2 <- sigma2_new
        log_lik_old <- log_lik_new
        break
      }
      
      lambda1 <- lambda1_new; lambda2 <- lambda2_new
      mu1 <- mu1_new; mu2 <- mu2_new
      sigma1 <- sigma1_new; sigma2 <- sigma2_new
      log_lik_old <- log_lik_new
    }
    
    if (is.finite(log_lik_old) && log_lik_old > best_log_lik) {
      best_log_lik <- log_lik_old
      best_result <- list(
        mu1 = mu1, mu2 = mu2,
        sigma1 = sigma1, sigma2 = sigma2,
        lambda1 = lambda1, lambda2 = lambda2,
        log_lik = log_lik_old,
        iterations = iter
      )
    }
  }
  
  if (is.null(best_result)) {
    # Fallback: return a very basic split
    m <- median(x)
    g1 <- x[x <= m]; g2 <- x[x > m]
    best_result <- list(
      mu1 = mean(g1), mu2 = mean(g2),
      sigma1 = max(sd(g1), 0.05), sigma2 = max(sd(g2), 0.05),
      lambda1 = length(g1)/n, lambda2 = length(g2)/n,
      log_lik = -Inf, iterations = 0
    )
  }
  
  # Ensure mu1 < mu2 for consistent output
  if (best_result$mu1 > best_result$mu2) {
    tmp <- best_result$mu1; best_result$mu1 <- best_result$mu2; best_result$mu2 <- tmp
    tmp <- best_result$sigma1; best_result$sigma1 <- best_result$sigma2; best_result$sigma2 <- tmp
    tmp <- best_result$lambda1; best_result$lambda1 <- best_result$lambda2; best_result$lambda2 <- tmp
  }
  
  return(best_result)
}

# ── Find intersection(s) of two weighted normal densities ──
find_intersections <- function(mu1, mu2, sigma1, sigma2, lambda1) {
  lambda2 <- 1 - lambda1
  f_diff <- function(x) {
    lambda1 * dnorm(x, mu1, sigma1) - lambda2 * dnorm(x, mu2, sigma2)
  }
  
  # Search range
  lo <- min(mu1 - 4*sigma1, mu2 - 4*sigma2)
  hi <- max(mu1 + 4*sigma1, mu2 + 4*sigma2)
  
  intersections <- c()
  
  # Grid search for sign changes
  grid <- seq(lo, hi, length.out = 300)
  vals <- sapply(grid, f_diff)
  
  for (i in 1:(length(grid)-1)) {
    if (is.finite(vals[i]) && is.finite(vals[i+1]) && vals[i] * vals[i+1] <= 0) {
      tryCatch({
        root <- uniroot(f_diff, c(grid[i], grid[i+1]), tol = 1e-6)$root
        # Check if this root is sufficiently different from existing ones
        if (length(intersections) == 0 || min(abs(root - intersections)) > 0.05) {
          intersections <- c(intersections, root)
        }
      }, error = function(e) {})
    }
  }
  
  # If no intersection found, use the midpoint of the two means (weighted by density)
  if (length(intersections) == 0) {
    intersections <- (mu1 * lambda2 + mu2 * lambda1) / (lambda1 + lambda2)
  }
  
  return(sort(intersections))
}

# ── Main analysis ──
# Filter and clean data
threshold_val <- ${threshold}
x <- x_raw
x <- x[!is.na(x) & is.finite(x)]
if (is.finite(threshold_val) && threshold_val > 0) {
  x <- x[x < threshold_val]
}
n_total <- length(x_raw)
n_used <- length(x)

if (n_used < 20) {
  stop(paste("Insufficient data. Only", n_used, "valid data points after filtering. Need at least 20."))
}

# Fit single normal (1-component model)
mu0 <- mean(x)
sigma0 <- sd(x)
if (sigma0 < 0.001) sigma0 <- 0.01
log_lik_1 <- sum(dnorm(x, mu0, sigma0, log = TRUE))
bic_1 <- -2 * log_lik_1 + 2 * log(n_used)

# Fit 2-component mixture
em_res <- em_two_normals(x)
log_lik_2 <- em_res$log_lik
bic_2 <- -2 * log_lik_2 + 5 * log(n_used)

# Find cutoff(s)
cutoffs <- find_intersections(em_res$mu1, em_res$mu2, em_res$sigma1, em_res$sigma2, em_res$lambda1)

# Separation index
pooled_sd <- sqrt((em_res$sigma1^2 + em_res$sigma2^2) / 2)
separation <- abs(em_res$mu1 - em_res$mu2) / pooled_sd

# BIC difference
bic_diff <- bic_1 - bic_2

# Verdict
if (bic_diff > 10 && separation > 2.0) {
  verdict <- "Strongly Bimodal"
  verdict_class <- "bimodal-strong"
} else if (bic_diff > 6 && separation > 1.5) {
  verdict <- "Moderately Bimodal"
  verdict_class <- "bimodal-moderate"
} else if (bic_diff > 2 && separation > 1.0) {
  verdict <- "Weakly Bimodal"
  verdict_class <- "bimodal-weak"
} else {
  verdict <- "Not Clearly Bimodal"
  verdict_class <- "unimodal"
}

# ── Plotting ──
webr::canvas(width = 700, height = 450, canvas_id = "plot-canvas-target")

par(mar = c(4.5, 4.5, 2.5, 1.5), bg = "white", fg = "#2d3436", col.axis = "#555", col.lab = "#333")

# Histogram
hist(x, breaks = min(80, max(30, round(n_used/8))), 
     freq = FALSE, col = "#dfe6e9", border = "white",
     xlab = "Cq Value", ylab = "Density",
     main = paste0("Cq Distribution (n=", n_used, ")"),
     cex.main = 1.1, cex.lab = 1.0)

# Generate smooth x values for density curves
xx <- seq(min(x) - 0.5, max(x) + 0.5, length.out = 400)

# Component densities
comp1_y <- em_res$lambda1 * dnorm(xx, em_res$mu1, em_res$sigma1)
comp2_y <- em_res$lambda2 * dnorm(xx, em_res$mu2, em_res$sigma2)
total_y <- comp1_y + comp2_y

# Draw component 1 (dashed blue)
lines(xx, comp1_y, col = "#0984e3", lwd = 2, lty = 2)
# Draw component 2 (dashed dark green)
lines(xx, comp2_y, col = "#00b894", lwd = 2, lty = 2)
# Draw total mixture (solid red)
lines(xx, total_y, col = "#e17055", lwd = 2.5)

# Draw cutoff lines
for (i in seq_along(cutoffs)) {
