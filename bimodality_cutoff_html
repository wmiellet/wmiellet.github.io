        // ─────────────────────────────────────
        // Run analysis
        // ─────────────────────────────────────
        async function runAnalysis(useSampleData = false) {
            if (!webRReady) {
                alert('WebR is still initializing. Please wait.');
                return;
            }

            const columnName = colSelect.value;
            const threshold = parseFloat(thresholdInput.value) || 40;

            if (!useSampleData && !columnName) {
                alert('Please select a Cq column to analyze.');
                return;
            }
            if (!useSampleData && !csvData) {
                alert('Please upload a CSV file first.');
                return;
            }

            // Reset previous plot
            resetResults();
            if (currentPlotCanvas && currentPlotCanvas.parentNode) {
                currentPlotCanvas.parentNode.removeChild(currentPlotCanvas);
            }
            currentPlotCanvas = null;
            plotPlaceholder.style.display = 'block';
            plotPlaceholder.textContent = 'Running analysis...';

            showLoading('Running EM algorithm...', 'Fitting 2-component normal mixture model');

            try {
                // If using uploaded data, write it to the WebR virtual filesystem
                if (!useSampleData && csvData) {
                    await webR.writeFile('/home/webr/data.csv', csvData);
                }

                // Remove any existing target canvas
                const existingCanvas = document.getElementById('plot-canvas-target');
                if (existingCanvas && existingCanvas.parentNode) {
                    existingCanvas.parentNode.removeChild(existingCanvas);
                }

                // Build and run R code
                const rCode = buildRCode(columnName, threshold, useSampleData);
                console.log('Running R analysis...');
                const result = await webR.evalR(rCode);

                // Convert WebR result to JS object
                const res = await result.toObject();
                console.log('Analysis result:', res);

                // Find the plot canvas (WebR creates it with our specified ID)
                // Wait a tiny bit for DOM update
                await new Promise(resolve => setTimeout(resolve, 150));
                const plotCanvas = document.getElementById('plot-canvas-target');
                if (plotCanvas) {
                    // Move it to our plot container
                    plotContainer.innerHTML = '';
                    plotContainer.appendChild(plotCanvas);
                    currentPlotCanvas = plotCanvas;
                    plotPlaceholder.style.display = 'none';
                } else {
                    // Fallback: look for any new canvas
                    const allCanvases = document.querySelectorAll('canvas');
                    for (const c of allCanvases) {
                        if (c.id === 'plot-canvas-target' || (!c.dataset.handled && c.width > 100)) {
                            c.dataset.handled = 'true';
                            plotContainer.innerHTML = '';
                            plotContainer.appendChild(c);
                            currentPlotCanvas = c;
                            plotPlaceholder.style.display = 'none';
                            break;
                        }
                    }
                    if (!currentPlotCanvas) {
                        plotPlaceholder.textContent =
                            'Plot rendered but could not be displayed. Check browser console.';
                    }
                }

                // Display results
                displayResults(res);

                setStatus('ready', `Analysis complete. ${res.verdict}.`);
            } catch (err) {
                console.error('Analysis error:', err);
                plotPlaceholder.textContent = 'Error during analysis: ' + err.message;
                setStatus('error', 'Analysis failed: ' + err.message);
                alert('Analysis failed: ' + err.message);
            } finally {
                hideLoading();
            }
        }

        // ─────────────────────────────────────
        // Display results
        // ─────────────────────────────────────
        function displayResults(res) {
            resultsCard.style.display = 'block';
            verdictBadge.textContent = res.verdict;
            verdictBadge.className = 'verdict ' + (res.verdict_class || 'unimodal');

            const items = [
                { label: 'BIC (1-comp)', value: res.bic_1, hint: 'Single normal' },
                { label: 'BIC (2-comp)', value: res.bic_2, hint: 'Mixture model' },
                { label: 'BIC Difference', value: res.bic_diff, hint: '> 2 favors bimodal' },
                { label: 'Separation', value: res.separation, hint: '|μ₁−μ₂| / σ_pooled' },
                { label: 'Component 1 Mean', value: res.mu1, hint: 'Lower component' },
                { label: 'Component 2 Mean', value: res.mu2, hint: 'Higher component' },
                { label: 'SD₁ / SD₂', value: res.sigma1 + ' / ' + res.sigma2, hint: 'Standard deviations' },
                { label: 'Mixing Proportion', value: (res.lambda1 * 100).toFixed(1) + '% / ' + (res.lambda2 * 100).toFixed(
                        1) + '%',
                    hint: 'λ₁ / λ₂' },
                { label: 'Cutoff Value(s)', value: res.cutoff, hint: 'Density intersection(s)' },
                { label: 'Data Points', value: res.n_used + ' / ' + res.n_total, hint: 'Used / Total' },
                { label: 'EM Iterations', value: res.iterations, hint: 'Until convergence' },
            ];

            resultsGrid.innerHTML = items.map(item => `
            <div class="result-badge">
              <div class="value">${item.value}</div>
              <div class="label">${item.label}</div>
              <div style="font-size:0.7rem;color:#999;margin-top:1px;">${item.hint}</div>
            </div>
          `).join('');
        }

        // ─────────────────────────────────────
        // Event listeners
        // ─────────────────────────────────────
        analyzeBtn.addEventListener('click', () => runAnalysis(false));
        sampleBtn.addEventListener('click', () => {
            // Pre-fill with sample data mode
            colSelect.value = colSelect.options[1]?.value || '';
            colSelect.disabled = true;
            thresholdInput.value = '45';
            analyzeBtn.disabled = false;
            fileInfo.classList.remove('visible');
            csvData = null;
            resetResults();
            setStatus('ready', 'Using generated sample data. Click "Analyze Bimodality" to run.');
            runAnalysis(true);
        });

        // Enable analyze button when column is selected
        colSelect.addEventListener('change', () => {
            analyzeBtn.disabled = !colSelect.value && !csvData;
        });

        // ─────────────────────────────────────
        // Startup
        // ─────────────────────────────────────
        async function startup() {
            try {
                await initWebR();
                // Enable sample data button immediately
                sampleBtn.disabled = false;
            } catch (err) {
                setStatus('error', 'WebR failed to load. Please refresh the page.');
                console.error(err);
            }
        }

        startup();
    </script>
