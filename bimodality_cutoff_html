}

# Shade the region between cutoffs (if there are 2)
if (length(cutoffs) >= 2) {
  c1 <- cutoffs[1]
  c2 <- cutoffs[length(cutoffs)]
  idx <- which(xx >= c1 & xx <= c2)
  if (length(idx) > 1) {
